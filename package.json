{
  "name": "@tsumugu/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Tsumugu Core \u2014 public graded Chinese reader (desktop-first).",
  "scripts": {
    "predev": "tsx scripts/vendor-fonts.ts && tsx scripts/build-blog.ts",
    "dev": "vite",
    "build:blog": "tsx scripts/build-blog.ts",
    "build": "tsx scripts/vendor-fonts.ts && tsx scripts/build-blog.ts && vite build && node --experimental-strip-types scripts/build-sitemap.ts",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "publish:readings": "tsx pipeline/publish-readings.ts",
    "companion:convert": "tsx scripts/companion/convert-drafts.ts",
    "companion:publish": "tsx scripts/companion/publish.ts",
    "gen:reading": "tsx scripts/gen/cli.ts",
    "accc:reconcile": "tsx scripts/accc/reconcile-grammar-index.ts",
    "accc:resolve": "tsx scripts/accc/resolve-lesson-target.ts",
    "accc:eval-g2pw": "tsx scripts/accc/eval-g2pw-polyphones.ts"
  },
  "dependencies": {
    "@tsumugu/engine": "workspace:*",
    "@tsumugu/gen-qa": "workspace:*",
    "content-pipeline": "workspace:*",
    "jieba-wasm": "^2.2.0",
    "opencc-js": "^1.0.5",
    "sql.js": "^1.12.0",
    "wavesurfer.js": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-tc": "^5.2.9",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "happy-dom": "^15.11.0",
    "lxgw-wenkai-tc-webfont": "^1.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0"
  },
  "packageManager": "pnpm@11.5.1"
}
